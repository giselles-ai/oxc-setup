{
  "name": "@giselles-ai/oxc-setup",
  "version": "0.1.0",
  "description": "Interactive CLI to set up oxlint, oxfmt, and optional CI in a Node.js project.",
  "keywords": [
    "ci",
    "cli",
    "node",
    "oxc",
    "oxfmt",
    "oxlint",
    "setup"
  ],
  "homepage": "https://github.com/giselles-ai/oxc-setup#readme",
  "bugs": {
    "url": "https://github.com/giselles-ai/oxc-setup/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giselles-ai/oxc-setup.git"
  },
  "files": [
    "dist"
  ],
  "packageManager": "bun@1.3.10",
  "type": "module",
  "bin": {
    "oxc-setup": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup && tsc --noEmit",
    "release:dry-run": "bun publish --dry-run",
    "release": "bun publish"
  }
}
